root = true

[*.{kt,kts}]
# Spotless/ktlint enforces only auto-formattable style here; non-autofixable
# checks (wildcard imports, line length, naming) are left to detekt + baseline
# so formatting stays a no-touch autofix and existing code isn't churned.
ktlint_standard_no-wildcard-imports = disabled
ktlint_standard_max-line-length = disabled
ktlint_standard_property-naming = disabled
