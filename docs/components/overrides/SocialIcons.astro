// social icons, mirroring the prominent Help entry on docs sites like gotenberg.dev.
import Default from "@astrojs/starlight/components/SocialIcons.astro";
---

<a
  class="sl-help-link"
  href="https://github.com/bambamboole/pdf-ua-api/issues"
  target="_blank"
  rel="noopener"
>
  Help
</a>
<Default><slot /></Default>
