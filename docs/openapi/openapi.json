{
    "openapi": "3.1.1",
    "info": {
        "title": "PDF API",
        "version": "dev",
        "description": "HTML to PDF/A-3a conversion API with PDF/UA accessibility support and veraPDF validation"
    },
    "servers": [
        {
            "url": "http://localhost:8080"
        }
    ],
    "paths": {
        "/health": {
            "get": {
                "tags": [
                    "Health"
                ],
                "summary": "Health check",
                "description": "Returns the health status of the API. Always accessible without authentication.",
                "responses": {
                    "200": {
                        "description": "Service is healthy",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "status": {
                                            "type": "string"
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/schema": {
            "get": {
                "tags": [
                    "Rendering"
                ],
                "summary": "Get the template schema",
                "description": "Canonical JSON Schema (Draft 2020-12) for the template rendering payload. The response is a JSON Schema document describing the Template type accepted by /render/template, with builder metadata under x-pdfUa.",
                "responses": {
                    "200": {
                        "description": "Template JSON Schema",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/render/html": {
            "post": {
                "tags": [
                    "Rendering"
                ],
                "summary": "Render HTML to PDF",
                "description": "Renders HTML to a PDF/A-3a + PDF/UA document, or a JSON validation response when Accept is application/json.",
                "parameters": [
                    {
                        "name": "X-Upload-Url",
                        "in": "header",
                        "description": "Presigned PUT URL that receives the generated document.",
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/RenderHtmlRequest"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "PDF document or JSON validation response",
                        "content": {
                            "application/pdf": {
                                "schema": {
                                    "type": "string",
                                    "format": "binary"
                                }
                            },
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/RenderPdfResponse"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid request, empty HTML, or JSON/upload conflict"
                    },
                    "204": {
                        "description": "PDF uploaded successfully"
                    },
                    "502": {
                        "description": "Upload target rejected the request or was unreachable"
                    },
                    "500": {
                        "description": "Rendering failed"
                    }
                }
            }
        },
        "/render/template": {
            "post": {
                "tags": [
                    "Rendering"
                ],
                "summary": "Render a template to PDF",
                "description": "Renders a JSON template to a PDF/A-3a document, or a JSON validation response when Accept is application/json.",
                "parameters": [
                    {
                        "name": "X-Upload-Url",
                        "in": "header",
                        "description": "Presigned PUT URL that receives the generated document.",
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": [
                                    "template"
                                ],
                                "properties": {
                                    "data": {
                                        "type": "object",
                                        "description": "Per-block content overrides, keyed by block id. Object for most blocks; array of row objects for tables."
                                    },
                                    "options": {
                                        "type": "object",
                                        "properties": {
                                            "baseUrl": {
                                                "type": "string"
                                            },
                                            "title": {
                                                "type": "string"
                                            }
                                        }
                                    },
                                    "template": {
                                        "type": "object",
                                        "description": "Template document to render. See GET /schema for the canonical template schema."
                                    }
                                }
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "PDF document or JSON validation response",
                        "content": {
                            "application/pdf": {
                                "schema": {
                                    "type": "string",
                                    "format": "binary"
                                }
                            },
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/RenderPdfResponse"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid template, data, request, or JSON/upload conflict"
                    },
                    "204": {
                        "description": "PDF uploaded successfully"
                    },
                    "502": {
                        "description": "Upload target rejected the request or was unreachable"
                    },
                    "500": {
                        "description": "Rendering failed"
                    }
                }
            }
        },
        "/render/url": {
            "post": {
                "tags": [
                    "Rendering"
                ],
                "summary": "Render a URL to PDF",
                "description": "Fetches the HTML at the given URL and renders it to a PDF, or a JSON validation response when Accept is application/json.",
                "parameters": [
                    {
                        "name": "X-Upload-Url",
                        "in": "header",
                        "description": "Presigned PUT URL that receives the generated document.",
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/RenderUrlRequest"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "PDF document or JSON validation response",
                        "content": {
                            "application/pdf": {
                                "schema": {
                                    "type": "string",
                                    "format": "binary"
                                }
                            },
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/RenderPdfResponse"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid URL, fetch failure, or JSON/upload conflict"
                    },
                    "204": {
                        "description": "PDF uploaded successfully"
                    },
                    "502": {
                        "description": "Upload target rejected the request or was unreachable"
                    },
                    "500": {
                        "description": "Rendering failed"
                    }
                }
            }
        },
        "/render": {
            "post": {
                "tags": [
                    "Rendering"
                ],
                "summary": "Render HTML to image",
                "description": "Renders HTML to a PNG or JPEG image, or uploads it when X-Upload-Url is provided.",
                "parameters": [
                    {
                        "name": "X-Upload-Url",
                        "in": "header",
                        "description": "Presigned PUT URL that receives the generated document.",
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/RenderImageRequest"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "Rendered image",
                        "content": {
                            "image/png": {
                                "schema": {
                                    "type": "string",
                                    "format": "binary"
                                }
                            },
                            "image/jpeg": {
                                "schema": {
                                    "type": "string",
                                    "format": "binary"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid request or upload URL"
                    },
                    "204": {
                        "description": "Image uploaded successfully"
                    },
                    "502": {
                        "description": "Upload target rejected the request or was unreachable"
                    },
                    "500": {
                        "description": "Rendering failed"
                    }
                }
            }
        },
        "/validate": {
            "post": {
                "tags": [
                    "Validation"
                ],
                "summary": "Validate PDF",
                "description": "Validates a PDF against PDF/A-3a and PDF/UA-1 standards using veraPDF. Send PDF binary as request body.",
                "requestBody": {
                    "content": {
                        "application/pdf": {
                            "schema": {
                                "type": "string",
                                "format": "binary"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "Validation result",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ValidationResponse"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "PDF content is empty"
                    },
                    "500": {
                        "description": "Validation service error"
                    }
                }
            }
        },
        "/identify": {
            "post": {
                "tags": [
                    "Identification"
                ],
                "summary": "Identify PDF",
                "description": "Checks whether a PDF was produced by this API and returns its document UUID if found.",
                "requestBody": {
                    "content": {
                        "application/pdf": {
                            "schema": {
                                "type": "string",
                                "format": "binary"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "Identification result",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/IdentifyResponse"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "PDF content is empty or invalid"
                    },
                    "500": {
                        "description": "Failed to read PDF"
                    }
                }
            }
        }
    },
    "webhooks": {},
    "components": {
        "schemas": {
            "FileAttachment": {
                "type": "object",
                "title": "FileAttachment",
                "required": [
                    "name",
                    "content"
                ],
                "properties": {
                    "name": {
                        "type": "string"
                    },
                    "content": {
                        "type": "string"
                    },
                    "mimeType": {
                        "type": "string"
                    },
                    "description": {
                        "type": [
                            "string",
                            "null"
                        ]
                    },
                    "relationship": {
                        "type": "string"
                    }
                }
            },
            "RenderHtmlRequest": {
                "type": "object",
                "title": "RenderHtmlRequest",
                "required": [
                    "html"
                ],
                "properties": {
                    "html": {
                        "type": "string"
                    },
                    "baseUrl": {
                        "type": [
                            "string",
                            "null"
                        ]
                    },
                    "attachments": {
                        "type": [
                            "array",
                            "null"
                        ],
                        "items": {
                            "$ref": "#/components/schemas/FileAttachment"
                        }
                    },
                    "embedColorProfile": {
                        "type": "boolean"
                    }
                }
            },
            "ProfileResult": {
                "type": "object",
                "title": "ProfileResult",
                "required": [
                    "profile",
                    "specification",
                    "isCompliant",
                    "totalChecks",
                    "passedChecks",
                    "failedChecks"
                ],
                "properties": {
                    "profile": {
                        "type": "string"
                    },
                    "specification": {
                        "type": "string"
                    },
                    "isCompliant": {
                        "type": "boolean"
                    },
                    "totalChecks": {
                        "type": "integer"
                    },
                    "passedChecks": {
                        "type": "integer"
                    },
                    "failedChecks": {
                        "type": "integer"
                    }
                }
            },
            "CategoryResult": {
                "type": "object",
                "title": "CategoryResult",
                "required": [
                    "category",
                    "passedChecks",
                    "failedChecks"
                ],
                "properties": {
                    "category": {
                        "type": "string"
                    },
                    "passedChecks": {
                        "type": "integer"
                    },
                    "failedChecks": {
                        "type": "integer"
                    }
                }
            },
            "ValidationSummary": {
                "type": "object",
                "title": "ValidationSummary",
                "required": [
                    "totalChecks",
                    "passedChecks",
                    "failedChecks"
                ],
                "properties": {
                    "totalChecks": {
                        "type": "integer"
                    },
                    "passedChecks": {
                        "type": "integer"
                    },
                    "failedChecks": {
                        "type": "integer"
                    },
                    "categories": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/CategoryResult"
                        }
                    }
                }
            },
            "FontInfo": {
                "type": "object",
                "title": "FontInfo",
                "required": [
                    "name",
                    "embedded",
                    "type"
                ],
                "properties": {
                    "name": {
                        "type": "string"
                    },
                    "embedded": {
                        "type": "boolean"
                    },
                    "type": {
                        "type": "string"
                    }
                }
            },
            "DocumentInfo": {
                "type": "object",
                "title": "DocumentInfo",
                "required": [
                    "pages",
                    "tagged",
                    "structureElements",
                    "fonts",
                    "images"
                ],
                "properties": {
                    "pages": {
                        "type": "integer"
                    },
                    "tagged": {
                        "type": "boolean"
                    },
                    "language": {
                        "type": [
                            "string",
                            "null"
                        ]
                    },
                    "structureElements": {
                        "type": "integer"
                    },
                    "fonts": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/FontInfo"
                        }
                    },
                    "images": {
                        "type": "integer"
                    }
                }
            },
            "ValidationFailure": {
                "type": "object",
                "title": "ValidationFailure",
                "required": [
                    "profile",
                    "clause",
                    "testNumber",
                    "category",
                    "message"
                ],
                "properties": {
                    "profile": {
                        "type": "string"
                    },
                    "clause": {
                        "type": "string"
                    },
                    "testNumber": {
                        "type": "integer"
                    },
                    "category": {
                        "type": "string"
                    },
                    "message": {
                        "type": "string"
                    },
                    "location": {
                        "type": [
                            "string",
                            "null"
                        ]
                    },
                    "errorDetails": {
                        "type": [
                            "string",
                            "null"
                        ]
                    }
                }
            },
            "PdfMetadata": {
                "type": "object",
                "title": "PdfMetadata",
                "properties": {
                    "title": {
                        "type": [
                            "string",
                            "null"
                        ]
                    },
                    "subject": {
                        "type": [
                            "string",
                            "null"
                        ]
                    },
                    "author": {
                        "type": [
                            "string",
                            "null"
                        ]
                    },
                    "creator": {
                        "type": [
                            "string",
                            "null"
                        ]
                    },
                    "producer": {
                        "type": [
                            "string",
                            "null"
                        ]
                    },
                    "creationDate": {
                        "type": [
                            "string",
                            "null"
                        ]
                    }
                }
            },
            "ValidationResponse": {
                "type": "object",
                "title": "ValidationResponse",
                "required": [
                    "isCompliant",
                    "profiles",
                    "summary"
                ],
                "properties": {
                    "isCompliant": {
                        "type": "boolean"
                    },
                    "profiles": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/ProfileResult"
                        }
                    },
                    "summary": {
                        "$ref": "#/components/schemas/ValidationSummary"
                    },
                    "documentInfo": {
                        "oneOf": [
                            {
                                "$ref": "#/components/schemas/DocumentInfo"
                            },
                            {
                                "type": "null"
                            }
                        ]
                    },
                    "failures": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/ValidationFailure"
                        }
                    },
                    "metadata": {
                        "oneOf": [
                            {
                                "$ref": "#/components/schemas/PdfMetadata"
                            },
                            {
                                "type": "null"
                            }
                        ]
                    }
                }
            },
            "RenderPdfResponse": {
                "type": "object",
                "title": "RenderPdfResponse",
                "required": [
                    "validation",
                    "pdf"
                ],
                "properties": {
                    "validation": {
                        "$ref": "#/components/schemas/ValidationResponse"
                    },
                    "pdf": {
                        "type": "string"
                    }
                }
            },
            "RenderUrlRequest": {
                "type": "object",
                "title": "RenderUrlRequest",
                "required": [
                    "url"
                ],
                "properties": {
                    "url": {
                        "type": "string"
                    },
                    "attachments": {
                        "type": [
                            "array",
                            "null"
                        ],
                        "items": {
                            "$ref": "#/components/schemas/FileAttachment"
                        }
                    },
                    "embedColorProfile": {
                        "type": "boolean"
                    }
                }
            },
            "RenderImageRequest": {
                "type": "object",
                "title": "RenderImageRequest",
                "required": [
                    "html"
                ],
                "properties": {
                    "html": {
                        "type": "string"
                    },
                    "baseUrl": {
                        "type": [
                            "string",
                            "null"
                        ]
                    },
                    "format": {
                        "type": "string"
                    },
                    "width": {
                        "type": "integer"
                    }
                }
            },
            "IdentifyResponse": {
                "type": "object",
                "title": "IdentifyResponse",
                "properties": {
                    "documentId": {
                        "type": [
                            "string",
                            "null"
                        ]
                    }
                }
            }
        },
        "securitySchemes": {
            "bearerAuth": {
                "scheme": "bearer",
                "type": "http"
            }
        }
    },
    "security": [
        {
            "bearerAuth": []
        }
    ]
}
