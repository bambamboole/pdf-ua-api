{
    "openapi": "3.1.0",
    "info": {
        "title": "PDF API",
        "description": "HTML to PDF/A-3a conversion API with PDF/UA accessibility support and veraPDF validation",
        "version": "dev"
    },
    "servers": [
        {
            "url": "http://localhost:8080"
        }
    ],
    "paths": {
        "/render/html": {
            "post": {
                "summary": "Render HTML to PDF",
                "description": "Renders HTML to a PDF/A-3a + PDF/UA document.",
                "tags": [
                    "Rendering"
                ],
                "responses": {
                    "200": {
                        "description": "PDF document or JSON validation response",
                        "content": {
                            "application/pdf": {
                                "schema": {
                                    "type": "string",
                                    "format": "binary"
                                }
                            },
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "validation": {
                                            "$ref": "#/components/schemas/bambamboole.pdfua.http.ValidationResponse"
                                        },
                                        "pdf": {
                                            "type": "string"
                                        }
                                    },
                                    "required": [
                                        "validation",
                                        "pdf"
                                    ]
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid request or JSON/upload conflict"
                    },
                    "500": {
                        "description": "Rendering failed"
                    },
                    "204": {
                        "description": "PDF uploaded successfully"
                    },
                    "502": {
                        "description": "Upload target rejected the request or was unreachable"
                    }
                },
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/bambamboole.pdfua.http.RenderHtmlRequest"
                            }
                        }
                    }
                },
                "parameters": [
                    {
                        "name": "X-Upload-Url",
                        "in": "header",
                        "required": false,
                        "description": "Presigned PUT URL that receives the generated document.",
                        "schema": {
                            "type": "string"
                        }
                    }
                ]
            }
        },
        "/render/template": {
            "post": {
                "summary": "Render a template to PDF",
                "description": "Renders a JSON template to a PDF/A-3a document or JSON validation response.",
                "tags": [
                    "Rendering"
                ],
                "responses": {
                    "200": {
                        "description": "PDF document or JSON validation response",
                        "content": {
                            "application/pdf": {
                                "schema": {
                                    "type": "string",
                                    "format": "binary"
                                }
                            },
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "validation": {
                                            "$ref": "#/components/schemas/bambamboole.pdfua.http.ValidationResponse"
                                        },
                                        "pdf": {
                                            "type": "string"
                                        }
                                    },
                                    "required": [
                                        "validation",
                                        "pdf"
                                    ]
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid request or JSON/upload conflict",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/bambamboole.pdfua.http.ValidationErrorResponse"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Rendering failed"
                    },
                    "204": {
                        "description": "PDF uploaded successfully"
                    },
                    "502": {
                        "description": "Upload target rejected the request or was unreachable"
                    }
                },
                "parameters": [
                    {
                        "name": "X-Upload-Url",
                        "in": "header",
                        "required": false,
                        "description": "Presigned PUT URL that receives the generated document.",
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/bambamboole.pdfua.http.controller.RenderRequest"
                            }
                        }
                    }
                }
            }
        },
        "/render/url": {
            "post": {
                "summary": "Render a URL to PDF",
                "description": "Fetches the HTML at the given URL and renders it to a PDF or JSON validation response.",
                "tags": [
                    "Rendering"
                ],
                "responses": {
                    "200": {
                        "description": "PDF document or JSON validation response",
                        "content": {
                            "application/pdf": {
                                "schema": {
                                    "type": "string",
                                    "format": "binary"
                                }
                            },
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "validation": {
                                            "$ref": "#/components/schemas/bambamboole.pdfua.http.ValidationResponse"
                                        },
                                        "pdf": {
                                            "type": "string"
                                        }
                                    },
                                    "required": [
                                        "validation",
                                        "pdf"
                                    ]
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid request or JSON/upload conflict"
                    },
                    "500": {
                        "description": "Rendering failed"
                    },
                    "204": {
                        "description": "PDF uploaded successfully"
                    },
                    "502": {
                        "description": "Upload target rejected the request or was unreachable"
                    }
                },
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/bambamboole.pdfua.http.controller.RenderUrlRequest"
                            }
                        }
                    }
                },
                "parameters": [
                    {
                        "name": "X-Upload-Url",
                        "in": "header",
                        "required": false,
                        "description": "Presigned PUT URL that receives the generated document.",
                        "schema": {
                            "type": "string"
                        }
                    }
                ]
            }
        },
        "/render": {
            "post": {
                "summary": "Render HTML to image",
                "description": "Renders HTML to a PNG or JPEG image. Returns the image binary.",
                "tags": [
                    "Rendering"
                ],
                "responses": {
                    "200": {
                        "description": "Rendered image",
                        "content": {
                            "image/png": {
                                "schema": {
                                    "type": "string",
                                    "format": "binary"
                                }
                            },
                            "image/jpeg": {
                                "schema": {
                                    "type": "string",
                                    "format": "binary"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid request or upload URL"
                    },
                    "500": {
                        "description": "Rendering failed"
                    },
                    "204": {
                        "description": "Image uploaded successfully"
                    },
                    "502": {
                        "description": "Upload target rejected the request or was unreachable"
                    }
                },
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/bambamboole.pdfua.http.controller.RenderImageRequest"
                            }
                        }
                    }
                },
                "parameters": [
                    {
                        "name": "X-Upload-Url",
                        "in": "header",
                        "required": false,
                        "description": "Presigned PUT URL that receives the generated document.",
                        "schema": {
                            "type": "string"
                        }
                    }
                ]
            }
        },
        "/health": {
            "get": {
                "summary": "Health check",
                "description": "Returns the health status of the API. Always accessible without authentication.",
                "tags": [
                    "Health"
                ]
            }
        },
        "/identify": {
            "post": {
                "summary": "Identify PDF",
                "description": "Checks whether a PDF was produced by this API and returns its document UUID if found.",
                "tags": [
                    "Identification"
                ],
                "responses": {
                    "200": {
                        "description": "Identification result",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/bambamboole.pdfua.http.controller.IdentifyResponse"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "PDF content is empty or invalid"
                    },
                    "500": {
                        "description": "Failed to read PDF"
                    }
                }
            }
        },
        "/schema": {
            "get": {
                "summary": "Get the template schema",
                "description": "Canonical JSON Schema (Draft 2020-12) for the template rendering payload. The response is a JSON Schema document describing the Template type accepted by /render/template, with builder metadata under x-pdfUa.",
                "tags": [
                    "Rendering"
                ],
                "responses": {
                    "200": {
                        "description": "Template JSON Schema",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/validate": {
            "post": {
                "summary": "Validate PDF",
                "description": "Validates a PDF against PDF/A-3a and PDF/UA-1 standards using veraPDF. Send PDF binary as request body.",
                "tags": [
                    "Validation"
                ],
                "responses": {
                    "200": {
                        "description": "Validation result",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/bambamboole.pdfua.http.ValidationResponse"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "PDF content is empty"
                    },
                    "500": {
                        "description": "Validation service error"
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "bambamboole.pdfua.http.CategoryResult": {
                "type": "object",
                "properties": {
                    "category": {
                        "type": "string"
                    },
                    "failedChecks": {
                        "type": "integer"
                    },
                    "passedChecks": {
                        "type": "integer"
                    }
                },
                "required": [
                    "category",
                    "passedChecks",
                    "failedChecks"
                ]
            },
            "bambamboole.pdfua.http.DocumentInfo": {
                "type": "object",
                "properties": {
                    "fonts": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/bambamboole.pdfua.http.FontInfo"
                        }
                    },
                    "images": {
                        "type": "integer"
                    },
                    "language": {
                        "type": "string"
                    },
                    "pages": {
                        "type": "integer"
                    },
                    "structureElements": {
                        "type": "integer"
                    },
                    "tagged": {
                        "type": "boolean"
                    }
                },
                "required": [
                    "pages",
                    "tagged",
                    "structureElements",
                    "fonts",
                    "images"
                ]
            },
            "bambamboole.pdfua.http.FontInfo": {
                "type": "object",
                "properties": {
                    "embedded": {
                        "type": "boolean"
                    },
                    "name": {
                        "type": "string"
                    },
                    "type": {
                        "type": "string"
                    }
                },
                "required": [
                    "name",
                    "embedded",
                    "type"
                ]
            },
            "bambamboole.pdfua.http.PdfMetadata": {
                "type": "object",
                "properties": {
                    "author": {
                        "type": "string"
                    },
                    "creationDate": {
                        "type": "string"
                    },
                    "creator": {
                        "type": "string"
                    },
                    "producer": {
                        "type": "string"
                    },
                    "subject": {
                        "type": "string"
                    },
                    "title": {
                        "type": "string"
                    }
                }
            },
            "bambamboole.pdfua.http.ProfileResult": {
                "type": "object",
                "properties": {
                    "failedChecks": {
                        "type": "integer"
                    },
                    "isCompliant": {
                        "type": "boolean"
                    },
                    "passedChecks": {
                        "type": "integer"
                    },
                    "profile": {
                        "type": "string"
                    },
                    "specification": {
                        "type": "string"
                    },
                    "totalChecks": {
                        "type": "integer"
                    }
                },
                "required": [
                    "profile",
                    "specification",
                    "isCompliant",
                    "totalChecks",
                    "passedChecks",
                    "failedChecks"
                ]
            },
            "bambamboole.pdfua.http.RenderHtmlRequest": {
                "type": "object",
                "properties": {
                    "attachments": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/bambamboole.pdfua.template.FileAttachment"
                        }
                    },
                    "baseUrl": {
                        "type": "string"
                    },
                    "html": {
                        "type": "string"
                    }
                },
                "required": [
                    "html"
                ]
            },
            "bambamboole.pdfua.http.ValidationErrorResponse": {
                "type": "object",
                "properties": {
                    "error": {
                        "type": "string"
                    },
                    "issues": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/bambamboole.pdfua.template.ValidationIssue"
                        }
                    }
                },
                "required": [
                    "issues"
                ]
            },
            "bambamboole.pdfua.http.ValidationFailure": {
                "type": "object",
                "properties": {
                    "category": {
                        "type": "string"
                    },
                    "clause": {
                        "type": "string"
                    },
                    "errorDetails": {
                        "type": "string"
                    },
                    "location": {
                        "type": "string"
                    },
                    "message": {
                        "type": "string"
                    },
                    "profile": {
                        "type": "string"
                    },
                    "testNumber": {
                        "type": "integer"
                    }
                },
                "required": [
                    "profile",
                    "clause",
                    "testNumber",
                    "category",
                    "message"
                ]
            },
            "bambamboole.pdfua.http.ValidationResponse": {
                "type": "object",
                "properties": {
                    "documentInfo": {
                        "$ref": "#/components/schemas/bambamboole.pdfua.http.DocumentInfo"
                    },
                    "failures": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/bambamboole.pdfua.http.ValidationFailure"
                        }
                    },
                    "isCompliant": {
                        "type": "boolean"
                    },
                    "metadata": {
                        "$ref": "#/components/schemas/bambamboole.pdfua.http.PdfMetadata"
                    },
                    "profiles": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/bambamboole.pdfua.http.ProfileResult"
                        }
                    },
                    "summary": {
                        "$ref": "#/components/schemas/bambamboole.pdfua.http.ValidationSummary"
                    }
                },
                "required": [
                    "isCompliant",
                    "profiles",
                    "summary"
                ]
            },
            "bambamboole.pdfua.http.ValidationSummary": {
                "type": "object",
                "properties": {
                    "categories": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/bambamboole.pdfua.http.CategoryResult"
                        }
                    },
                    "failedChecks": {
                        "type": "integer"
                    },
                    "passedChecks": {
                        "type": "integer"
                    },
                    "totalChecks": {
                        "type": "integer"
                    }
                },
                "required": [
                    "totalChecks",
                    "passedChecks",
                    "failedChecks"
                ]
            },
            "bambamboole.pdfua.http.controller.IdentifyResponse": {
                "type": "object",
                "properties": {
                    "documentId": {
                        "type": "string"
                    }
                }
            },
            "bambamboole.pdfua.http.controller.RenderImageRequest": {
                "type": "object",
                "properties": {
                    "baseUrl": {
                        "type": "string"
                    },
                    "format": {
                        "type": "string"
                    },
                    "html": {
                        "type": "string"
                    },
                    "width": {
                        "type": "integer"
                    }
                },
                "required": [
                    "html"
                ]
            },
            "bambamboole.pdfua.http.controller.RenderPdfResponse": {
                "type": "object",
                "properties": {
                    "pdf": {
                        "type": "string"
                    },
                    "validation": {
                        "$ref": "#/components/schemas/bambamboole.pdfua.http.ValidationResponse"
                    }
                },
                "required": [
                    "validation",
                    "pdf"
                ]
            },
            "bambamboole.pdfua.http.controller.RenderUrlRequest": {
                "type": "object",
                "properties": {
                    "attachments": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/bambamboole.pdfua.template.FileAttachment"
                        }
                    },
                    "url": {
                        "type": "string"
                    }
                },
                "required": [
                    "url"
                ]
            },
            "bambamboole.pdfua.template.FileAttachment": {
                "type": "object",
                "properties": {
                    "content": {
                        "type": "string"
                    },
                    "description": {
                        "type": "string"
                    },
                    "mimeType": {
                        "type": "string"
                    },
                    "name": {
                        "type": "string"
                    },
                    "relationship": {
                        "type": "string"
                    }
                },
                "required": [
                    "name",
                    "content"
                ]
            },
            "bambamboole.pdfua.template.ValidationIssue": {
                "type": "object",
                "properties": {
                    "code": {
                        "type": "string"
                    },
                    "message": {
                        "type": "string"
                    },
                    "path": {
                        "type": "string"
                    }
                },
                "required": [
                    "path",
                    "code",
                    "message"
                ]
            },
            "kotlin.collections.Map.Entry_Of_String_and_JsonElement": {
                "type": "object",
                "properties": {
                    "key": {
                        "type": "string"
                    },
                    "value": {
                        "$ref": "#/components/schemas/kotlinx.serialization.json.JsonElement"
                    }
                },
                "required": [
                    "key",
                    "value"
                ]
            },
            "kotlinx.serialization.json.JsonArray": {
                "type": "object",
                "properties": {
                    "size": {
                        "type": "integer"
                    }
                }
            },
            "kotlinx.serialization.json.JsonElement": {
                "type": "object",
                "oneOf": [
                    {
                        "$ref": "#/components/schemas/kotlinx.serialization.json.JsonArray"
                    },
                    {
                        "$ref": "#/components/schemas/kotlinx.serialization.json.JsonObject"
                    },
                    {
                        "$ref": "#/components/schemas/kotlinx.serialization.json.JsonPrimitive"
                    }
                ],
                "discriminator": {
                    "propertyName": "type",
                    "mapping": {
                        "kotlinx.serialization.json.JsonArray": "#/components/schemas/kotlinx.serialization.json.JsonArray",
                        "kotlinx.serialization.json.JsonObject": "#/components/schemas/kotlinx.serialization.json.JsonObject",
                        "kotlinx.serialization.json.JsonPrimitive": "#/components/schemas/kotlinx.serialization.json.JsonPrimitive"
                    }
                }
            },
            "kotlinx.serialization.json.JsonObject": {
                "type": "object",
                "properties": {
                    "entries": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/kotlin.collections.Map.Entry_Of_String_and_JsonElement"
                        }
                    },
                    "keys": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    },
                    "size": {
                        "type": "integer"
                    },
                    "values": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/kotlinx.serialization.json.JsonElement"
                        }
                    }
                }
            },
            "kotlinx.serialization.json.JsonPrimitive": {
                "type": "object",
                "properties": {
                    "content": {
                        "type": "string"
                    },
                    "isString": {
                        "type": "boolean"
                    }
                },
                "required": [
                    "isString",
                    "content"
                ]
            },
            "bambamboole.pdfua.http.controller.RenderRequest": {
                "type": "object",
                "properties": {
                    "data": {
                        "type": "object",
                        "description": "Per-block content overrides, keyed by block id. Object for most blocks; array of row objects for tables.",
                        "additionalProperties": true
                    },
                    "options": {
                        "type": "object",
                        "properties": {
                            "baseUrl": {
                                "type": "string"
                            },
                            "title": {
                                "type": "string"
                            }
                        }
                    },
                    "template": {
                        "type": "object",
                        "description": "Template document to render. See GET /schema for the canonical template schema."
                    }
                },
                "required": [
                    "template"
                ]
            }
        },
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "scheme": "bearer"
            }
        }
    }
}