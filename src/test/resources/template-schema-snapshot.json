{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pdf-ua-api.com/schemas/template-v2.json",
  "title": "Template",
  "type": "object",
  "properties": {
    "version": {
      "type": "integer",
      "const": 2
    },
    "config": {
      "$ref": "#/$defs/templateConfig"
    },
    "fonts": {
      "type": "object",
      "description": "External fonts keyed by font family name.",
      "additionalProperties": {
        "$ref": "#/$defs/fontFace"
      }
    },
    "attachments": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/fileAttachment"
      }
    },
    "rows": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/row"
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "version"
  ],
  "$defs": {
    "pageFormat": {
      "type": "string",
      "title": "PageFormat",
      "enum": [
        "A3",
        "A4",
        "A5",
        "A6",
        "Letter",
        "Legal",
        "Tabloid"
      ]
    },
    "orientation": {
      "type": "string",
      "title": "Orientation",
      "enum": [
        "portrait",
        "landscape"
      ]
    },
    "presetPageSize": {
      "type": "object",
      "title": "PresetPageSize",
      "properties": {
        "format": {
          "$ref": "#/$defs/pageFormat"
        },
        "orientation": {
          "$ref": "#/$defs/orientation"
        }
      },
      "additionalProperties": false
    },
    "customPageSize": {
      "type": "object",
      "title": "CustomPageSize",
      "properties": {
        "width": {
          "type": "integer",
          "minimum": 1.0
        },
        "height": {
          "type": "integer",
          "minimum": 1.0
        }
      },
      "required": [
        "width",
        "height"
      ],
      "additionalProperties": false
    },
    "pageSize": {
      "oneOf": [
        {
          "$ref": "#/$defs/presetPageSize"
        },
        {
          "$ref": "#/$defs/customPageSize"
        }
      ],
      "title": "PageSize"
    },
    "spacingConfig": {
      "type": "object",
      "title": "SpacingConfig",
      "properties": {
        "top": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Top spacing in millimetres.",
          "minimum": 0.0
        },
        "right": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Right spacing in millimetres.",
          "minimum": 0.0
        },
        "bottom": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Bottom spacing in millimetres.",
          "minimum": 0.0
        },
        "left": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Left spacing in millimetres.",
          "minimum": 0.0
        }
      },
      "additionalProperties": false
    },
    "align": {
      "type": "string",
      "title": "Align",
      "enum": [
        "left",
        "center",
        "right"
      ]
    },
    "pageNumbersConfig": {
      "type": "object",
      "title": "PageNumbersConfig",
      "properties": {
        "enabled": {
          "type": "boolean",
          "x-pdfUaDefault": false
        },
        "position": {
          "$ref": "#/$defs/align",
          "x-pdfUaDefault": "center"
        }
      },
      "additionalProperties": false
    },
    "pageBackgroundType": {
      "type": "string",
      "title": "PageBackgroundType",
      "enum": [
        "auto",
        "image",
        "pdf"
      ]
    },
    "pageBackgroundConfig": {
      "type": "object",
      "title": "PageBackgroundConfig",
      "properties": {
        "src": {
          "type": "string",
          "description": "HTTP, HTTPS, or base64 data URI for an image or PDF page background.",
          "minLength": 1
        },
        "type": {
          "$ref": "#/$defs/pageBackgroundType",
          "x-pdfUaDefault": "auto"
        }
      },
      "required": [
        "src"
      ],
      "additionalProperties": false
    },
    "symbology": {
      "type": "string",
      "title": "Symbology",
      "enum": [
        "qr",
        "datamatrix",
        "aztec",
        "pdf417",
        "code128",
        "code39",
        "ean13",
        "ean8",
        "upca",
        "upce",
        "itf14",
        "codabar",
        "gs1-128",
        "gs1-datamatrix",
        "gs1-qr",
        "gs1-databar",
        "gs1-databar-expanded",
        "swiss-qr"
      ]
    },
    "epc": {
      "type": "object",
      "title": "Epc",
      "properties": {
        "type": {
          "type": "string",
          "const": "epc"
        },
        "name": {
          "type": "string",
          "x-pdfUaGroup": "content"
        },
        "iban": {
          "type": "string",
          "x-pdfUaGroup": "content"
        },
        "bic": {
          "type": [
            "string",
            "null"
          ],
          "x-pdfUaGroup": "content"
        },
        "amount": {
          "type": [
            "string",
            "null"
          ],
          "description": "Amount in euros, such as 12.50.",
          "x-pdfUaGroup": "content"
        },
        "purpose": {
          "type": [
            "string",
            "null"
          ],
          "x-pdfUaGroup": "content"
        },
        "reference": {
          "type": [
            "string",
            "null"
          ],
          "x-pdfUaGroup": "content"
        },
        "remittance": {
          "type": [
            "string",
            "null"
          ],
          "x-pdfUaGroup": "content"
        }
      },
      "required": [
        "type",
        "name",
        "iban"
      ],
      "additionalProperties": false
    },
    "gs1Element": {
      "type": "object",
      "title": "Gs1Element",
      "properties": {
        "ai": {
          "type": "string",
          "description": "GS1 Application Identifier, such as 01 or 3103.",
          "x-pdfUaGroup": "content"
        },
        "value": {
          "type": "string",
          "x-pdfUaGroup": "content"
        }
      },
      "required": [
        "ai",
        "value"
      ],
      "additionalProperties": false
    },
    "gs1": {
      "type": "object",
      "title": "Gs1",
      "properties": {
        "type": {
          "type": "string",
          "const": "gs1"
        },
        "elements": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/gs1Element"
          },
          "x-pdfUaGroup": "content"
        }
      },
      "required": [
        "type",
        "elements"
      ],
      "additionalProperties": false
    },
    "raw": {
      "type": "object",
      "title": "Raw",
      "properties": {
        "type": {
          "type": "string",
          "const": "raw"
        },
        "value": {
          "type": "string",
          "x-pdfUaGroup": "content"
        }
      },
      "required": [
        "type",
        "value"
      ],
      "additionalProperties": false
    },
    "swissAddress": {
      "type": "object",
      "title": "SwissAddress",
      "properties": {
        "name": {
          "type": "string"
        },
        "street": {
          "type": [
            "string",
            "null"
          ]
        },
        "buildingNumber": {
          "type": [
            "string",
            "null"
          ]
        },
        "postalCode": {
          "type": "string"
        },
        "town": {
          "type": "string"
        },
        "country": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "postalCode",
        "town",
        "country"
      ],
      "additionalProperties": false
    },
    "swissReferenceType": {
      "type": "string",
      "title": "SwissReferenceType",
      "enum": [
        "QRR",
        "SCOR",
        "NON"
      ]
    },
    "swiss": {
      "type": "object",
      "title": "Swiss",
      "properties": {
        "type": {
          "type": "string",
          "const": "swiss"
        },
        "creditorIban": {
          "type": "string",
          "x-pdfUaGroup": "content"
        },
        "creditor": {
          "$ref": "#/$defs/swissAddress",
          "x-pdfUaGroup": "content"
        },
        "amount": {
          "type": [
            "string",
            "null"
          ],
          "description": "Amount in the given currency, such as 1949.75.",
          "x-pdfUaGroup": "content"
        },
        "currency": {
          "type": "string",
          "x-pdfUaDefault": "CHF",
          "x-pdfUaGroup": "content"
        },
        "debtor": {
          "oneOf": [
            {
              "$ref": "#/$defs/swissAddress"
            },
            {
              "type": "null"
            }
          ],
          "x-pdfUaGroup": "content"
        },
        "referenceType": {
          "$ref": "#/$defs/swissReferenceType",
          "x-pdfUaDefault": "NON",
          "x-pdfUaGroup": "content"
        },
        "reference": {
          "type": [
            "string",
            "null"
          ],
          "x-pdfUaGroup": "content"
        },
        "message": {
          "type": [
            "string",
            "null"
          ],
          "x-pdfUaGroup": "content"
        }
      },
      "required": [
        "type",
        "creditorIban",
        "creditor"
      ],
      "additionalProperties": false
    },
    "text": {
      "type": "object",
      "title": "Text",
      "properties": {
        "type": {
          "type": "string",
          "const": "text"
        },
        "text": {
          "type": "string",
          "x-pdfUaGroup": "content"
        }
      },
      "required": [
        "type",
        "text"
      ],
      "additionalProperties": false
    },
    "url": {
      "type": "object",
      "title": "Url",
      "properties": {
        "type": {
          "type": "string",
          "const": "url"
        },
        "url": {
          "type": "string",
          "x-pdfUaGroup": "content"
        }
      },
      "required": [
        "type",
        "url"
      ],
      "additionalProperties": false
    },
    "vcard": {
      "type": "object",
      "title": "Vcard",
      "properties": {
        "type": {
          "type": "string",
          "const": "vcard"
        },
        "firstName": {
          "type": "string",
          "x-pdfUaGroup": "content"
        },
        "lastName": {
          "type": "string",
          "x-pdfUaGroup": "content"
        },
        "org": {
          "type": [
            "string",
            "null"
          ],
          "x-pdfUaGroup": "content"
        },
        "title": {
          "type": [
            "string",
            "null"
          ],
          "x-pdfUaGroup": "content"
        },
        "phone": {
          "type": [
            "string",
            "null"
          ],
          "x-pdfUaGroup": "content"
        },
        "email": {
          "type": [
            "string",
            "null"
          ],
          "x-pdfUaGroup": "content"
        },
        "url": {
          "type": [
            "string",
            "null"
          ],
          "x-pdfUaGroup": "content"
        }
      },
      "required": [
        "type",
        "firstName",
        "lastName"
      ],
      "additionalProperties": false
    },
    "wifiSecurity": {
      "type": "string",
      "title": "WifiSecurity",
      "enum": [
        "WPA",
        "WEP",
        "nopass"
      ]
    },
    "wifi": {
      "type": "object",
      "title": "Wifi",
      "properties": {
        "type": {
          "type": "string",
          "const": "wifi"
        },
        "ssid": {
          "type": "string",
          "x-pdfUaGroup": "content"
        },
        "password": {
          "type": [
            "string",
            "null"
          ],
          "x-pdfUaGroup": "content"
        },
        "security": {
          "$ref": "#/$defs/wifiSecurity",
          "x-pdfUaDefault": "WPA",
          "x-pdfUaGroup": "content"
        },
        "hidden": {
          "type": "boolean",
          "x-pdfUaDefault": false,
          "x-pdfUaGroup": "content"
        }
      },
      "required": [
        "type",
        "ssid"
      ],
      "additionalProperties": false
    },
    "barcodeContent": {
      "oneOf": [
        {
          "$ref": "#/$defs/epc"
        },
        {
          "$ref": "#/$defs/gs1"
        },
        {
          "$ref": "#/$defs/raw"
        },
        {
          "$ref": "#/$defs/swiss"
        },
        {
          "$ref": "#/$defs/text"
        },
        {
          "$ref": "#/$defs/url"
        },
        {
          "$ref": "#/$defs/vcard"
        },
        {
          "$ref": "#/$defs/wifi"
        }
      ]
    },
    "typographyConfig": {
      "type": "object",
      "title": "TypographyConfig",
      "properties": {
        "family": {
          "type": [
            "string",
            "null"
          ],
          "description": "Bundled or external font family key."
        },
        "size": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Font size in points.",
          "minimum": 1.0
        },
        "weight": {
          "type": [
            "string",
            "null"
          ],
          "description": "Font weight; one of the FontWeight enum values.",
          "enum": [
            "300",
            "400",
            "500",
            "600",
            "700",
            null
          ]
        },
        "align": {
          "type": [
            "string",
            "null"
          ],
          "description": "Text alignment for this typography scope.",
          "enum": [
            "left",
            "center",
            "right",
            null
          ]
        },
        "color": {
          "type": [
            "string",
            "null"
          ],
          "description": "CSS color value used for text."
        }
      },
      "additionalProperties": false
    },
    "blockConfig": {
      "type": "object",
      "title": "BlockConfig",
      "properties": {
        "typography": {
          "oneOf": [
            {
              "$ref": "#/$defs/typographyConfig"
            },
            {
              "type": "null"
            }
          ],
          "x-pdfUaGroup": "style"
        },
        "spacing": {
          "oneOf": [
            {
              "$ref": "#/$defs/spacingConfig"
            },
            {
              "type": "null"
            }
          ],
          "x-pdfUaGroup": "layout"
        },
        "width": {
          "type": [
            "string",
            "null"
          ],
          "description": "CSS width for this block, such as 50%, 80mm, or auto.",
          "pattern": "^(auto|\\d+(\\.\\d+)?(mm|cm|in|px|pt|pc|em|rem|%|vw|vh|ch))$",
          "x-pdfUaGroup": "layout"
        },
        "align": {
          "type": [
            "string",
            "null"
          ],
          "description": "Horizontal placement of this block within its row cell.",
          "enum": [
            "left",
            "center",
            "right",
            null
          ],
          "x-pdfUaGroup": "layout"
        }
      },
      "additionalProperties": false,
      "tsType": "{ typography?: TypographyConfig; spacing?: SpacingConfig; width?: string | null; align?: Align | null }"
    },
    "barcodeBlock": {
      "type": "object",
      "title": "BarcodeBlock",
      "properties": {
        "type": {
          "type": "string",
          "const": "barcode"
        },
        "id": {
          "type": [
            "string",
            "null"
          ],
          "description": "Stable block identifier used for runtime data overrides."
        },
        "symbology": {
          "$ref": "#/$defs/symbology",
          "x-pdfUaGroup": "content"
        },
        "content": {
          "$ref": "#/$defs/barcodeContent",
          "x-pdfUaGroup": "content"
        },
        "height": {
          "type": [
            "string",
            "null"
          ],
          "description": "Rendered code height as a CSS length, such as 20mm or 96px.",
          "pattern": "^(auto|\\d+(\\.\\d+)?(mm|cm|in|px|pt|pc|em|rem|%|vw|vh|ch))$",
          "x-pdfUaGroup": "layout"
        },
        "config": {
          "$ref": "#/$defs/blockConfig"
        }
      },
      "required": [
        "type",
        "symbology",
        "content"
      ],
      "additionalProperties": false
    },
    "dividerStyle": {
      "type": "string",
      "title": "DividerStyle",
      "enum": [
        "solid",
        "dashed",
        "dotted",
        "double",
        "none"
      ]
    },
    "dividerBlock": {
      "type": "object",
      "title": "DividerBlock",
      "properties": {
        "type": {
          "type": "string",
          "const": "divider"
        },
        "id": {
          "type": [
            "string",
            "null"
          ],
          "description": "Stable block identifier used for runtime data overrides."
        },
        "thickness": {
          "type": "string",
          "description": "Rule thickness as a CSS length, such as 1pt or 2px.",
          "pattern": "^(auto|\\d+(\\.\\d+)?(mm|cm|in|px|pt|pc|em|rem|%|vw|vh|ch))$",
          "x-pdfUaDefault": "1pt",
          "x-pdfUaGroup": "style"
        },
        "lineColor": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{3,8}$",
          "x-pdfUaDefault": "#d1d5db",
          "x-pdfUaGroup": "style"
        },
        "style": {
          "$ref": "#/$defs/dividerStyle",
          "x-pdfUaDefault": "solid",
          "x-pdfUaGroup": "style"
        },
        "config": {
          "$ref": "#/$defs/blockConfig"
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "headingBlock": {
      "type": "object",
      "title": "HeadingBlock",
      "properties": {
        "type": {
          "type": "string",
          "const": "heading"
        },
        "id": {
          "type": [
            "string",
            "null"
          ],
          "description": "Stable block identifier used for runtime data overrides."
        },
        "text": {
          "type": "string",
          "x-pdfUaGroup": "content"
        },
        "level": {
          "type": "integer",
          "x-pdfUaDefault": 2,
          "minimum": 1.0,
          "maximum": 6.0,
          "x-pdfUaGroup": "content"
        },
        "config": {
          "$ref": "#/$defs/blockConfig"
        }
      },
      "required": [
        "type",
        "text"
      ],
      "additionalProperties": false
    },
    "htmlBlock": {
      "type": "object",
      "title": "HtmlBlock",
      "properties": {
        "type": {
          "type": "string",
          "const": "html"
        },
        "id": {
          "type": [
            "string",
            "null"
          ],
          "description": "Stable block identifier used for runtime data overrides."
        },
        "html": {
          "type": "string",
          "x-pdfUaGroup": "content"
        },
        "config": {
          "$ref": "#/$defs/blockConfig"
        }
      },
      "required": [
        "type",
        "html"
      ],
      "additionalProperties": false
    },
    "imageBlock": {
      "type": "object",
      "title": "ImageBlock",
      "properties": {
        "type": {
          "type": "string",
          "const": "image"
        },
        "id": {
          "type": [
            "string",
            "null"
          ],
          "description": "Stable block identifier used for runtime data overrides."
        },
        "src": {
          "type": "string",
          "description": "Public image URL, SVG markup, or uploaded image data URL.",
          "x-pdfUaGroup": "content"
        },
        "alt": {
          "type": "string",
          "description": "Alternative text for screen readers and PDF accessibility.",
          "x-pdfUaDefault": "",
          "x-pdfUaGroup": "content"
        },
        "maxHeight": {
          "type": "string",
          "description": "Maximum rendered height as a CSS length, such as 60px or 20mm.",
          "pattern": "^(auto|\\d+(\\.\\d+)?(mm|cm|in|px|pt|pc|em|rem|%|vw|vh|ch))$",
          "x-pdfUaDefault": "60px",
          "x-pdfUaGroup": "layout"
        },
        "config": {
          "$ref": "#/$defs/blockConfig"
        }
      },
      "required": [
        "type",
        "src"
      ],
      "additionalProperties": false
    },
    "keyValueField": {
      "type": "object",
      "title": "KeyValueField",
      "properties": {
        "key": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9_]*$"
        },
        "label": {
          "type": "string"
        }
      },
      "required": [
        "key",
        "label"
      ],
      "additionalProperties": false,
      "tsType": "{ key: string; label: string }"
    },
    "keyValueBlock": {
      "type": "object",
      "title": "KeyValueBlock",
      "properties": {
        "type": {
          "type": "string",
          "const": "key-value"
        },
        "id": {
          "type": [
            "string",
            "null"
          ],
          "description": "Stable block identifier used for runtime data overrides."
        },
        "values": {
          "type": "object",
          "title": "KeyValueValues",
          "propertyNames": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_]*$"
          },
          "additionalProperties": {
            "type": [
              "string",
              "null"
            ]
          },
          "x-pdfUaGroup": "data"
        },
        "labelWidth": {
          "type": "string",
          "pattern": "^(auto|\\d+(\\.\\d+)?(mm|cm|in|px|pt|pc|em|rem|%|vw|vh|ch))$",
          "x-pdfUaDefault": "30mm",
          "x-pdfUaGroup": "layout"
        },
        "fields": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/keyValueField"
          },
          "x-pdfUaGroup": "content"
        },
        "config": {
          "$ref": "#/$defs/blockConfig"
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "spacerBlock": {
      "type": "object",
      "title": "SpacerBlock",
      "properties": {
        "type": {
          "type": "string",
          "const": "spacer"
        },
        "id": {
          "type": [
            "string",
            "null"
          ],
          "description": "Stable block identifier used for runtime data overrides."
        },
        "height": {
          "type": "string",
          "description": "Vertical space as a CSS length, such as 5mm or 12px.",
          "pattern": "^(auto|\\d+(\\.\\d+)?(mm|cm|in|px|pt|pc|em|rem|%|vw|vh|ch))$",
          "x-pdfUaDefault": "5mm",
          "x-pdfUaGroup": "layout"
        },
        "config": {
          "$ref": "#/$defs/blockConfig"
        }
